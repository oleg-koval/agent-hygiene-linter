{
  "name": "agent-hygiene-linter",
  "version": "1.0.0",
  "description": "CLI linter that scores repo hygiene for agents and humans",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": {
    "name": "Oleg Koval",
    "email": "oleg@bizcuit.nl",
    "url": "https://olegkoval.com"
  },
  "homepage": "https://oleg-koval.github.io/agent-hygiene-linter/",
  "repository": {
    "type": "git",
    "url": "https://github.com/oleg-koval/agent-hygiene-linter.git"
  },
  "bugs": {
    "url": "https://github.com/oleg-koval/agent-hygiene-linter/issues"
  },
  "keywords": [
    "hygiene",
    "lint",
    "agents",
    "cli",
    "typescript"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "bin": {
    "agent-hygiene-linter": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.26.0",
    "lefthook": "^1.11.0",
    "prettier": "^3.5.3",
    "semantic-release": "^25.0.5",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "tsup",
    "lint:repo": "npm run build && node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage",
    "semantic-release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "prepare": "lefthook install"
  }
}
